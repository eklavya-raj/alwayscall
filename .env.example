EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Optional fallback if you still use the legacy key name:
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_STREAM_API_KEY=your-stream-api-key
EXPO_PUBLIC_STREAM_PUSH_PROVIDER_ANDROID=production-fcm-video
EXPO_PUBLIC_STREAM_PUSH_PROVIDER_IOS=production-apn-video

# Configure these as Supabase Edge Function secrets, not in the Expo app:
STREAM_API_KEY=your-stream-api-key
STREAM_API_SECRET=your-stream-api-secret
